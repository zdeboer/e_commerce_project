<% content_for :breadcrumbs do %>
  <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
  <li class="breadcrumb-item active" aria-current="page">Cart</li>
<% end %>

<h1>Your Cart</h1>

<% if @line_items.any? %>
  <table>
    <thead>
      <tr>
        <th>Product</th>
        <th>Variation</th>
        <th>Qty</th>
        <th>Subtotal</th>
        <th></th>
      </tr>
    </thead>

    <tbody>
      <% @line_items.each do |line| %>
        <tr>
          <td>
            <%= link_to line[:product].name, product_path(line[:product]) %>
          </td>

          <td>
            <%= [line[:variation].variation_name, line[:variation].variation_value].compact.join(": ") %>
          </td>

          <td>
            <%= form_with url: cart_item_path(line[:variation].id), method: :patch, local: true do %>
              <%= number_field_tag :quantity, line[:quantity], min: 1 %>
              <%= submit_tag "Update" %>
            <% end %>
          </td>

          <td>
            <%= number_to_currency(line[:subtotal]) %>
          </td>

          <td>
            <%= button_to "Remove", cart_item_path(line[:variation].id), method: :delete %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div>
    <%= link_to "Proceed to checkout", checkout_path %>
  </div>

<% else %>
  <p>Your cart is empty.</p>
<% end %>