<h1>My Orders</h1>

<% if @orders&.any? %>
  <table>
    <tr>
      <th>Order #</th>
      <th>Date</th>
      <th>Total</th>
      <th>Status</th>
    </tr>

    <% @orders.each do |order| %>
      <tr>
        <td><%= link_to order.id, order_path(order) %></td>
        <td><%= order.order_date&.strftime("%Y-%m-%d") || order.created_at.strftime("%Y-%m-%d") %></td>
        <td><%= number_to_currency(order.total_amount) %></td>
        <td><%= order.order_status.capitalize %></td>
      </tr>
    <% end %>
  </table>
  
<% else %>
  <p>No orders yet.</p>
<% end %>