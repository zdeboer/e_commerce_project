<% content_for :breadcrumbs do %>
  <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
  <li class="breadcrumb-item"><%= link_to "Orders", orders_path %></li>
  <li class="breadcrumb-item active" aria-current="page">Order <%= @order.id %></li>
<% end %>

<h1>Order Placed</h1>

<p><strong>Order:</strong> <%= @order.id %></p>
<p><strong>Status:</strong> <%= @order.order_status %> / <%= @order.payment_status %></p>
<p><strong>Province:</strong> <%= @province_code.presence || (@order.address&.state || "—") %></p>

<h2>Items</h2>

<table>
  <thead>
    <tr>
      <th>Product</th>
      <th>Variation</th>
      <th>Qty</th>
      <th>Unit</th>
      <th>Line Total</th>
    </tr>
  </thead>

  <tbody>
    <% @items.each do |item| %>
      <% variation = item.product_variation %>
      <% product = variation&.product %>

      <tr>
        <td><%= product&.name || "—" %></td>

        <td>
          <%= [variation&.variation_name, variation&.variation_value].compact.join(": ").presence || "—" %>
        </td>

        <td><%= item.quantity.to_i %></td>

        <td><%= number_to_currency(item.unit_price) %></td>

        <td><%= number_to_currency(item.total_price) %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<h2>Totals</h2>

<p><strong>Subtotal:</strong> <%= number_to_currency(@subtotal) %></p>
<p><strong>GST:</strong> <%= number_to_currency(@taxes[:gst]) %></p>
<p><strong>PST:</strong> <%= number_to_currency(@taxes[:pst]) %></p>
<p><strong>HST:</strong> <%= number_to_currency(@taxes[:hst]) %></p>

<p><strong>Total:</strong> <%= number_to_currency(@total) %></p>

<% if @order.order_status_new? %>
  <%= button_to "Pay with Stripe",
        "/checkout/create",
        method: :post,
        params: { order_id: @order.id } %>
<% end %>