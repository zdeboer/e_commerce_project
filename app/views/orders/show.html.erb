<h1>Order placed</h1>

<p>Order  <%= @order.id %></p>
<p>Status: <%= @order.order_status %> / <%= @order.payment_status %></p>
<p>Province: <%= @province_code.presence || (@order.address&.state || "—") %></p>

<h2>Items</h2>

<table style="border-collapse:collapse;width:100%;max-width:900px;">
  <thead>
    <tr>
      <th style="text-align:left;border-bottom:1px solid #ddd;padding:8px;">Product</th>
      <th style="text-align:left;border-bottom:1px solid #ddd;padding:8px;">Variation</th>
      <th style="text-align:right;border-bottom:1px solid #ddd;padding:8px;">Qty</th>
      <th style="text-align:right;border-bottom:1px solid #ddd;padding:8px;">Unit</th>
      <th style="text-align:right;border-bottom:1px solid #ddd;padding:8px;">Line total</th>
    </tr>
  </thead>
  <tbody>
    <% @items.each do |item| %>
      <% variation = item.product_variation %>
      <% product = variation&.product %>
      <tr>
        <td style="border-bottom:1px solid #eee;padding:8px;"><%= product&.name || "—" %></td>
        <td style="border-bottom:1px solid #eee;padding:8px;">
          <%= [variation&.variation_name, variation&.variation_value].compact.join(": ").presence || "—" %>
        </td>
        <td style="border-bottom:1px solid #eee;padding:8px;text-align:right;"><%= item.quantity.to_i %></td>
        <td style="border-bottom:1px solid #eee;padding:8px;text-align:right;"><%= number_to_currency(item.unit_price) %></td>
        <td style="border-bottom:1px solid #eee;padding:8px;text-align:right;"><%= number_to_currency(item.total_price) %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<h2>Totals</h2>

<p>Subtotal: <%= number_to_currency(@subtotal) %></p>
<p>GST: <%= number_to_currency(@taxes[:gst]) %></p>
<p>PST: <%= number_to_currency(@taxes[:pst]) %></p>
<p>HST: <%= number_to_currency(@taxes[:hst]) %></p>
<p><strong>Total: <%= number_to_currency(@total) %></strong></p>

<% if @order.order_status_new? %>
  <%= button_to "Pay with Stripe",
        "/checkout/create",
        method: :post,
        params: { order_id: @order.id } %>
<% end %>