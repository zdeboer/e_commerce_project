<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "E Commerce Project" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body>
    <header style="border-bottom:1px solid #eee;padding:12px 16px;">
      <nav style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
        <%= link_to "Home", root_path %>
        <%= link_to "Products", products_path %>
        <%= link_to "Cart", cart_path %>
        <%= link_to "Orders", orders_path %>
        <a href="/admin">Admin</a>
        <% if customer_signed_in? %>
        <%= button_to "Sign out", destroy_customer_session_path, method: :delete, form: { style: "display:inline" } %>
        <% else %>
        <%= link_to "Sign up", new_customer_registration_path %>
        <%= link_to "Sign in", new_customer_session_path %>
        <% end %>
      </nav>
    </header>

    <main style="padding:16px;max-width:960px;margin:0 auto;">
      <%= yield %>
    </main>
  </body>
</html>
