<% content_for :breadcrumbs do %>
  <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
  <li class="breadcrumb-item"><%= link_to "Orders", orders_path %></li>
  <li class="breadcrumb-item active" aria-current="page">Payment Successful</li>
<% end %>

<h1>Payment Successful</h1>

<p>Thank you for your purchase. Your payment has been processed successfully.</p>

<h2>Order Summary</h2>

<ul>
  <li><strong>Order Number:</strong> <%= @order.id %></li>
  <li><strong>Total Paid:</strong> <%= number_to_currency(@order.total_amount) %></li>
  <li><strong>Status:</strong> <%= @order.order_status.capitalize %></li>
</ul>

<p>
  <%= link_to "View Your Order", order_path(@order) %>
</p>

<p>
  <%= link_to "Continue Shopping", products_path %>
</p>