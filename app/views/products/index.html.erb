<% content_for :title, "Products" %>

<% content_for :breadcrumbs do %>
  <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
  <li class="breadcrumb-item active" aria-current="page">Products</li>
<% end %>

<h1>Products</h1>

<%= form_with url: products_path, method: :get, local: true do %>
  <div class="product-filters">
    <%= text_field_tag :q, params[:q], placeholder: "Search products…" %>

    <%= select_tag :genre_id,
      options_from_collection_for_select(@genres, :id, :name, params[:genre_id]),
      include_blank: "All genres" %>

    <%= select_tag :sort,
      options_for_select(
        [
          ["Name (A–Z)", ""],
          ["Newest", "newest"],
          ["Recently updated", "updated"]
        ],
        params[:sort].to_s
      ) %>

    <%= submit_tag "Search" %>

    <% if params[:q].present? || params[:genre_id].present? || params[:sort].present? %>
      <%= link_to "Clear", products_path %>
    <% end %>
  </div>
<% end %>

<% if @products.any? %>
  <div class="product-grid">
    <% @products.each do |product| %>
      <div class="product-card">
        <% if product.image_url.present? %>
          <div class="product-image">
            <%= image_tag product.image_url, alt: product.name, loading: "lazy" %>
          </div>
        <% end %>

        <div class="product-name">
          <%= link_to product.name, product_path(product) %>
        </div>

        <div class="product-meta">
          <%= product.genre&.name %>
          <% if product.media_type.present? %>
            · <%= product.media_type.name %>
          <% end %>
        </div>

        <div class="product-price">
          <%= number_to_currency(product.price) if product.price.present? %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="pagination-block">
    <%= paginate @products, params: request.query_parameters %>
  </div>

<% else %>
  <p>No products found.</p>
<% end %>