<% content_for :title, @product.name %>

<% content_for :breadcrumbs do %>
  <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
  <li class="breadcrumb-item"><%= link_to "Products", products_path %></li>
  <li class="breadcrumb-item active" aria-current="page"><%= @product.name %></li>
<% end %>

<h1><%= @product.name %></h1>

<% if @product.image_url.present? %>
  <div class="product-image">
    <%= image_tag @product.image_url, alt: @product.name %>
  </div>
<% end %>

<p>
  <strong>Price:</strong>
  <%= number_to_currency(@product.price) if @product.price.present? %>
</p>

<p>
  <strong>Genre:</strong>
  <%= @product.genre&.name %>
</p>

<p>
  <strong>Media type:</strong>
  <%= @product.media_type&.name %>
</p>

<% if @product.description.present? %>
  <h2>Description</h2>
  <p><%= @product.description %></p>
<% end %>

<h2>Available Formats</h2>

<% if @variations.any? %>
  <table>
    <thead>
      <tr>
        <th>Option</th>
        <th>SKU</th>
        <th>In Stock</th>
        <th></th>
      </tr>
    </thead>

    <tbody>
      <% @variations.each do |variation| %>
        <tr>
          <td>
            <%= [variation.variation_name, variation.variation_value].compact.join(": ") %>
          </td>

          <td>
            <%= variation.sku.presence || "—" %>
          </td>

          <td>
            <%= variation.inventory&.quantity || 0 %>
          </td>

          <td>
            <%= form_with url: cart_items_path, method: :post, local: true do %>
              <%= hidden_field_tag :product_variation_id, variation.id %>
              <%= submit_tag "Add" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No variations available.</p>
<% end %>